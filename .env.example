# ============================================================
# Lyra Secretary v1.3 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# --- Core ---
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-min-32-chars       # Any random string, min 32 characters

# --- Database ---
DATABASE_URL=sqlite:///./data/lyra.db          # Default SQLite path (relative to backend/)

# --- Redis ---
REDIS_URL=redis://localhost:6379/0             # Docker Compose overrides this to redis://redis:6379/0
REDIS_PASSWORD=                                # Leave empty for local development

# --- User Context (Critical) ---
USER_TIMEZONE=Africa/Cairo                     # IANA timezone — all scheduling is relative to this
USER_ID=user_primary                           # Single-user system, leave as-is

# --- OpenClaw notification bridge ---
# Telegram delivery is owned by the existing OpenClaw bot. Lyra only queues
# operator alerts into notifications:pending:{OPENCLAW_OPERATOR_USER_ID};
# OpenClaw polls and relays them through its current Telegram runtime.
OPENCLAW_OPERATOR_USER_ID=1
OPENCLAW_OPERATOR_NOTIFICATIONS_ENABLED=true
OPENCLAW_MIRROR_USER_NOTIFICATIONS=true  # Redacted mirror metadata only

# --- Alpha feedback widget (Optional — alembic 040, 2026-04-28) ---
# Primary channel: Resend (https://resend.com — free 100/day). Without
# RESEND_API_KEY, feedback still records to DB and queues an OpenClaw operator
# alert if configured. Either or both can be unset.
# OPERATOR_EMAIL is the recipient. All LyraOS outbound email should come
# from hello@lyraos.org; make sure the domain is verified in Resend.
RESEND_API_KEY=
OPERATOR_EMAIL=
FEEDBACK_FROM_EMAIL=hello@lyraos.org
USER_EMAIL_FROM=hello@lyraos.org

# --- Pre-scale containment switches ---
# Set LYRA_SAFE_MODE=read_only_pressure to keep academic pressure readable while
# suppressing higher-risk recovery nudges and provider progress inference.
LYRA_SAFE_MODE=
LYRA_BASEET_PRESSURE_INPUT_ENABLED=true
LYRA_PROVIDER_PROGRESS_SIGNALS_ENABLED=true
LYRA_RECOVERY_NUDGES_ENABLED=true

# --- Monitoring (Optional) ---
SENTRY_DSN=                                    # Leave empty to disable error tracking
